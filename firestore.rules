rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields:
    //   - language: string ('biblical' | 'modern')
    //   - lastActive: number
    //
    // Collection: /users/{userId}/progress/{wordId}
    // Fields:
    //   - wordId: string
    //   - mastery: string ('new' | 'learning' | 'mastered')
    //   - correctCount: number
    //   - incorrectCount: number
    //   - lastStudied: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aisaacsaul@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['language', 'lastActive', 'role', 'streak', 'lastStreakUpdate', 'streakFreezes', 'totalLearningTime', 'displayName', 'deleted', 'deletedAt', 'isPremium', 'email', 'createdAt', 'reviewPromptShown']) &&
             (!('language' in data) || data.language is string) &&
             (!('lastActive' in data) || data.lastActive is number) &&
             (!('streak' in data) || data.streak is number) &&
             (!('lastStreakUpdate' in data) || data.lastStreakUpdate is number) &&
             (!('streakFreezes' in data) || data.streakFreezes is number) &&
             (!('totalLearningTime' in data) || data.totalLearningTime is number) &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt is number) &&
             (!('isPremium' in data) || data.isPremium is bool) &&
             (!('email' in data) || data.email is string) &&
             (!('createdAt' in data) || data.createdAt is number) &&
             (!('reviewPromptShown' in data) || data.reviewPromptShown is bool) &&
             (!('role' in data) || data.role is string);
    }

    function isValidProgress(data) {
      return data.keys().hasOnly(['wordId', 'mastery', 'correctCount', 'incorrectCount', 'lastStudied', 'interval', 'nextReview']) &&
             data.wordId is string &&
             (data.mastery == 'new' || data.mastery == 'learning' || data.mastery == 'mastered') &&
             data.correctCount is number &&
             data.incorrectCount is number &&
             (!('lastStudied' in data) || data.lastStudied is number) &&
             (!('interval' in data) || data.interval is number) &&
             (!('nextReview' in data) || data.nextReview is number);
    }

    function isValidCustomDeck(data) {
      return data.keys().hasAll(['title', 'words', 'createdAt', 'updatedAt']) &&
             data.title is string &&
             (!('description' in data) || data.description is string) &&
             data.words is list &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    function isValidSharedDeck(data) {
      return data.keys().hasAll(['title', 'words', 'createdAt', 'authorId']) &&
             data.title is string &&
             (!('description' in data) || data.description is string) &&
             data.words is list &&
             data.createdAt is number &&
             data.authorId is string;
    }

    function isValidShopDoc(data) {
      return data.keys().hasAll(['title', 'description', 'content', 'language', 'price', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.content is string && data.content.size() <= 100000 &&
             data.language is string &&
             data.price is number &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /shopContent/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /sharedDecks/{deckId} {
      allow read: if true; // Anyone can read a shared deck
      allow create: if isAuthenticated() && isValidSharedDeck(request.resource.data) && request.resource.data.authorId == request.auth.uid;
    }

    match /pro_waitlist/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'userId', 'timestamp']) &&
                    request.resource.data.email is string &&
                    request.resource.data.timestamp is number;
      allow read: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.get('role', '') == resource.data.get('role', '') || isAdmin());

      match /progress/{wordId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidProgress(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /decks/{deckId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidCustomDeck(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /verificationCodes/{email} {
      allow read, write: if false; 
    }

    function isValidReview(data) {
      return data.keys().hasOnly(['name', 'role', 'text', 'comment', 'rating', 'date', 'userId', 'id']) &&
             data.name is string &&
             data.comment is string &&
             data.rating is number &&
             data.date is string &&
             (!('id' in data) || data.id is string) &&
             data.userId is string;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(request.resource.data);
      allow delete, update: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
