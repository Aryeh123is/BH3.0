rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields:
    //   - language: string ('biblical' | 'modern')
    //   - lastActive: number
    //
    // Collection: /users/{userId}/progress/{wordId}
    // Fields:
    //   - wordId: string
    //   - mastery: string ('new' | 'learning' | 'mastered')
    //   - correctCount: number
    //   - incorrectCount: number
    //   - lastStudied: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aisaacsaul@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['language', 'lastActive', 'role']) &&
             (data.language == 'biblical' || data.language == 'modern') &&
             data.lastActive is number;
    }

    function isValidProgress(data) {
      return data.keys().hasOnly(['wordId', 'mastery', 'correctCount', 'incorrectCount', 'lastStudied', 'interval', 'nextReview']) &&
             data.wordId is string &&
             (data.mastery == 'new' || data.mastery == 'learning' || data.mastery == 'mastered') &&
             data.correctCount is number &&
             data.incorrectCount is number &&
             data.lastStudied is number &&
             data.interval is number &&
             data.nextReview is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());

      match /progress/{wordId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidProgress(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
