{
  "entities": {
    "UserProgress": {
      "title": "UserProgress",
      "description": "Tracks a user's mastery of a specific word.",
      "type": "object",
      "properties": {
        "wordId": { "type": "string", "description": "The ID of the word." },
        "mastery": { "type": "string", "enum": ["new", "learning", "mastered"], "description": "The current mastery level." },
        "correctCount": { "type": "integer", "description": "Number of times the word was answered correctly." },
        "incorrectCount": { "type": "integer", "description": "Number of times the word was answered incorrectly." },
        "lastStudied": { "type": "integer", "description": "Timestamp of the last study session." },
        "interval": { "type": "integer", "description": "The current review interval in days." },
        "nextReview": { "type": "integer", "description": "Timestamp of the next scheduled review." }
      },
      "required": ["wordId", "mastery", "correctCount", "incorrectCount", "lastStudied", "interval", "nextReview"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user preferences and metadata.",
      "type": "object",
      "properties": {
        "language": { "type": "string", "enum": ["biblical", "modern", "spanish", "french"], "description": "The preferred language." },
        "lastActive": { "type": "integer", "description": "Timestamp of the last activity." },
        "streak": { "type": "integer", "description": "Current user learning streak." },
        "lastStreakUpdate": { "type": "integer", "description": "Timestamp streak was last updated." },
        "streakFreezes": { "type": "integer", "description": "Number of streak freezes." },
        "totalLearningTime": { "type": "integer", "description": "Total learning time in seconds." },
        "displayName": { "type": "string", "description": "User's display name." },
        "deleted": { "type": "boolean", "description": "Whether the user account is soft deleted." },
        "deletedAt": { "type": "integer", "description": "Timestamp when the account was deleted." },
        "isPremium": { "type": "boolean", "description": "Premium status." },
        "role": { "type": "string", "description": "Role of the user (admin)." }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and settings."
    },
    "/users/{userId}/progress/{wordId}": {
      "schema": "UserProgress",
      "description": "User's progress for a specific word."
    }
  }
}
